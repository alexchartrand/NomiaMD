# Copy to .env and fill in. python-dotenv loads this automatically if you add
# `from dotenv import load_dotenv; load_dotenv()` at the top of app/main.py, or export
# these in your shell before running uvicorn.

# Points at LocalAI's OpenAI-compatible endpoint. Adjust the port/model to match your
# LocalAI setup — NOMIAMD_MODEL must match a model name configured there.
NOMIAMD_BASE_URL=http://localhost:8080/v1
NOMIAMD_API_KEY=
NOMIAMD_MODEL="lfm2.5-1.2b-instruct"

# For baseline testing against a real (non-local) model before self-hosting — only use
# with synthetic patient data (see README's "Before using real patient data" section,
# Law 25). Any OpenAI-compatible endpoint works here without touching engine.py:
#   OpenRouter (proxies GPT/Claude/Mistral/Llama/Qwen under one key):
#     NOMIAMD_BASE_URL=https://openrouter.ai/api/v1
#     NOMIAMD_API_KEY=<your OpenRouter key>
#     NOMIAMD_MODEL=mistral/mistral-small-latest   # or openai/gpt-4o-mini, etc.
#   Mistral's native API (strong French-language performance):
#     NOMIAMD_BASE_URL=https://api.mistral.ai/v1
#     NOMIAMD_API_KEY=<your Mistral key>
#     NOMIAMD_MODEL=mistral-small-latest

# Semantic (embedding) retrieval for RAMQ billing-code candidates — complements BM25 via
# RRF fusion (app/ramq/reference.py). Optional: unset NOMIAMD_EMBEDDING_API_KEY and the
# pipeline falls back to BM25-only, unchanged.
#
# The RAMQ code corpus itself is pre-embedded by the ramq-ingestion repo and shipped as
# app/ramq/ramq_embeddings_section_b.jsonl — this repo never re-embeds it. Only each new
# transcript is embedded live, and it's automatically sent to whatever embedding_model that
# file recorded (currently mistralai/mistral-embed-2312), so NOMIAMD_EMBEDDING_MODEL below
# does NOT need to match it — just point NOMIAMD_EMBEDDING_BASE_URL at a gateway that can
# actually serve that model id, e.g. OpenRouter:
NOMIAMD_EMBEDDING_API_KEY=
NOMIAMD_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# Only used as a fallback default when no precomputed embeddings file is available (e.g. a
# small ad-hoc table built in code/tests) — the real RAMQ pipeline ignores this.
NOMIAMD_EMBEDDING_MODEL=text-embedding-3-small

# Defaults to a local SQLite file if unset. Point this at Postgres for anything beyond
# local development, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/nomiamd
DATABASE_URL=
